{
    "name": "wefabric/wp-video-indexer",
    "description": "Indexes platform videos in WordPress post content as VideoObject schema markup.",
    "license": "proprietary",
    "authors": [
        {
            "name": "Leo Flapper",
            "email": "leo@wefabric.nl"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "Wefabric\\WPVideoIndexer\\": "./src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wefabric\\WPVideoIndexer\\Tests\\": "./tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wefabric\\WPVideoIndexer\\Providers\\ServiceProvider"
            ]
        }
    }
}
